generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  user_id                             Int                 @id @default(autoincrement())
  nome                                String              @db.VarChar(100)
  cpf                                 String              @unique @db.VarChar(14)
  email                               String              @unique @db.VarChar(100)
  senha_hash                          String              @db.VarChar(255)
  tel_user                            String              @db.VarChar(15)
  ativo                               Boolean?            @default(false)
  codigo                              String?             @db.VarChar(10)
  codigoExpiraEm                      DateTime?           @db.Timestamp(6)
  tipoCodigo                          String?             @db.VarChar(255)
  created_at                          DateTime?           @default(now()) @db.Timestamp(6)
  updated_at                          DateTime?           @updatedAt
  chat_chat_destinatario_idTousuarios chat[]              @relation("chat_destinatario_idTousuarios")
  chat_chat_remetente_idTousuarios    chat[]              @relation("chat_remetente_idTousuarios")
  empresa_usuario                     empresa_usuario[]
  logs_pagamentos                     logs_pagamentos[]
  logs_usuarios                       logs_usuarios[]
  motoristas                          motoristas[]
  responsaveis                        responsaveis[]
  usuarios_endereco                   usuarios_endereco[]

  @@map("usuarios")
}

model chat {
  mensagem_id                             Int       @id @default(autoincrement())
  remetente_id                            Int
  destinatario_id                         Int
  conteudo                                String?
  data_envio                              DateTime? @default(now()) @db.Timestamp(6)
  lida                                    Boolean?  @default(false)
  usuarios_chat_destinatario_idTousuarios Usuario   @relation("chat_destinatario_idTousuarios", fields: [destinatario_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  usuarios_chat_remetente_idTousuarios    Usuario   @relation("chat_remetente_idTousuarios", fields: [remetente_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model criancas {
  crianca_id            Int                     @id @default(autoincrement())
  empresa_id            Int
  nome                  String                  @db.VarChar(100)
  dt_nascimento         DateTime                @db.Date
  cpf                   String                  @unique @db.VarChar(14)
  ativo                 Boolean?                @default(true)
  escola_id             Int
  plano_id              Int?
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  updated_at            DateTime?               @default(now()) @db.Timestamp(6)
  empresas              empresas                @relation(fields: [empresa_id], references: [empresa_id], onDelete: Cascade, onUpdate: NoAction)
  escolas               escolas                 @relation(fields: [escola_id], references: [escola_id], onDelete: NoAction, onUpdate: NoAction)
  planos_transporte     planos_transporte?      @relation(fields: [plano_id], references: [plano_id], onDelete: NoAction, onUpdate: NoAction)
  criancas_responsaveis criancas_responsaveis[]
  pagamento_crianca     pagamento_crianca[]
  pagamentos            pagamentos[]
  rotina_transporte     rotina_transporte[]
}

model criancas_responsaveis {
  crianca_id          Int
  responsavel_id      Int
  tipo_responsavel_id Int?
  principal           Boolean?          @default(false)
  created_at          DateTime?         @default(now()) @db.Timestamp(6)
  criancas            criancas          @relation(fields: [crianca_id], references: [crianca_id], onDelete: Cascade, onUpdate: NoAction)
  responsaveis        responsaveis      @relation(fields: [responsavel_id], references: [responsavel_id], onDelete: Cascade, onUpdate: NoAction)
  tipo_responsavel    tipo_responsavel? @relation(fields: [tipo_responsavel_id], references: [tipo_responsavel_id], onDelete: NoAction, onUpdate: NoAction)

  @@id([crianca_id, responsavel_id])
}

model dias_semana {
  dia_id            Int                 @id @default(autoincrement())
  nome              String              @unique @db.VarChar(20)
  rotina_transporte rotina_transporte[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model empresa_usuario {
  empresa_id Int
  user_id    Int
  papel      String    @db.VarChar(30)
  ativo      Boolean?  @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  empresas   empresas  @relation(fields: [empresa_id], references: [empresa_id], onDelete: Cascade, onUpdate: NoAction)
  usuarios   Usuario   @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([empresa_id, user_id])
}

model empresas {
  empresa_id             Int                      @id @default(autoincrement())
  nome                   String                   @db.VarChar(100)
  cnpj                   String?                  @unique @db.VarChar(18)
  email_contato          String?                  @db.VarChar(100)
  telefone_contato       String?                  @db.VarChar(15)
  ativo                  Boolean?                 @default(true)
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  updated_at             DateTime?                @default(now()) @db.Timestamp(6)
  criancas               criancas[]
  empresa_usuario        empresa_usuario[]
  localizacao_real_tempo localizacao_real_tempo[]
  motoristas             motoristas[]
  pagamentos             pagamentos[]
  rotina_transporte      rotina_transporte[]
  veiculos               veiculos[]
}

model enderecos {
  endereco_id                                                        Int                 @id @default(autoincrement())
  rua                                                                String              @db.VarChar(120)
  numero                                                             String?             @db.VarChar(20)
  complemento                                                        String?             @db.VarChar(200)
  bairro                                                             String              @db.VarChar(80)
  cidade                                                             String              @db.VarChar(80)
  estado                                                             String              @db.VarChar(2)
  cep                                                                String              @db.VarChar(10)
  latitude                                                           Decimal?            @db.Decimal(9, 6)
  longitude                                                          Decimal?            @db.Decimal(9, 6)
  referencia                                                         String?             @db.VarChar(255)
  created_at                                                         DateTime?           @default(now()) @db.Timestamp(6)
  updated_at                                                         DateTime?           @default(now()) @db.Timestamp(6)
  escola_endereco                                                    escola_endereco[]
  rotina_transporte_rotina_transporte_endereco_destino_idToenderecos rotina_transporte[] @relation("rotina_transporte_endereco_destino_idToenderecos")
  rotina_transporte_rotina_transporte_endereco_origem_idToenderecos  rotina_transporte[] @relation("rotina_transporte_endereco_origem_idToenderecos")
  usuarios_endereco                                                  usuarios_endereco[]
}

model escola_endereco {
  escola_id   Int
  endereco_id Int
  principal   Boolean?  @default(true)
  enderecos   enderecos @relation(fields: [endereco_id], references: [endereco_id], onDelete: Cascade, onUpdate: NoAction)
  escolas     escolas   @relation(fields: [escola_id], references: [escola_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([escola_id, endereco_id])
}

model escolas {
  escola_id       Int               @id @default(autoincrement())
  nome            String            @db.VarChar(100)
  tipo_escola_id  Int
  ativo           Boolean?          @default(true)
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  updated_at      DateTime?         @default(now()) @db.Timestamp(6)
  criancas        criancas[]
  escola_endereco escola_endereco[]
  tipo_escola     tipo_escola       @relation(fields: [tipo_escola_id], references: [tipo_escola_id], onDelete: NoAction, onUpdate: NoAction)
}

model forma_pagamento {
  forma_pag_id Int          @id @default(autoincrement())
  forma        String       @db.VarChar(50)
  pagamentos   pagamentos[]
}

model localizacao_real_tempo {
  localizacao_id Int        @id @default(autoincrement())
  empresa_id     Int
  motorista_id   Int
  latitude       Decimal?   @db.Decimal(9, 6)
  longitude      Decimal?   @db.Decimal(9, 6)
  data_hora      DateTime?  @default(now()) @db.Timestamp(6)
  empresas       empresas   @relation(fields: [empresa_id], references: [empresa_id], onDelete: Cascade, onUpdate: NoAction)
  motoristas     motoristas @relation(fields: [motorista_id], references: [motorista_id], onDelete: NoAction, onUpdate: NoAction)
}

model logs_pagamentos {
  log_id         Int         @id @default(autoincrement())
  ocorrencia     String      @db.VarChar(100)
  mensagem       String
  user_id        Int
  pagamento_id   Int?
  data_tentativa DateTime?   @default(now()) @db.Timestamp(6)
  pagamentos     pagamentos? @relation(fields: [pagamento_id], references: [pagamento_id], onDelete: NoAction, onUpdate: NoAction)
  usuarios       Usuario     @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model logs_usuarios {
  log_id       Int       @id @default(autoincrement())
  procedimento String    @db.VarChar(100)
  mensagem     String
  detalhe      String?
  user_id      Int
  data_evento  DateTime? @default(now()) @db.Timestamp(6)
  usuarios     Usuario   @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model motorista_veiculo {
  motorista_id Int
  data_inicio  DateTime?  @default(now()) @db.Timestamp(6)
  data_fim     DateTime?  @db.Timestamp(6)
  veiculo_id   Int
  motoristas   motoristas @relation(fields: [motorista_id], references: [motorista_id], onDelete: Cascade, onUpdate: NoAction)
  veiculos     veiculos   @relation(fields: [veiculo_id], references: [veiculo_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([motorista_id, veiculo_id])
}

model motoristas {
  motorista_id           Int                      @id @default(autoincrement())
  empresa_id             Int
  user_id                Int
  cnh                    String                   @unique @db.VarChar(20)
  status_cnh             Boolean
  ativo                  Boolean?                 @default(true)
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  updated_at             DateTime?                @default(now()) @db.Timestamp(6)
  localizacao_real_tempo localizacao_real_tempo[]
  motorista_veiculo      motorista_veiculo[]
  empresas               empresas                 @relation(fields: [empresa_id], references: [empresa_id], onDelete: Cascade, onUpdate: NoAction)
  usuarios               Usuario                  @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  rotina_transporte      rotina_transporte[]
}

model pagamento_crianca {
  pagamento_id Int
  crianca_id   Int
  valor_base   Decimal    @db.Decimal(10, 2)
  desconto     Decimal?   @default(0) @db.Decimal(10, 2)
  multa        Decimal?   @default(0) @db.Decimal(10, 2)
  reajuste     Decimal?   @default(0) @db.Decimal(10, 2)
  valor_final  Decimal    @db.Decimal(10, 2)
  criancas     criancas   @relation(fields: [crianca_id], references: [crianca_id], onDelete: Cascade, onUpdate: NoAction)
  pagamentos   pagamentos @relation(fields: [pagamento_id], references: [pagamento_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([pagamento_id, crianca_id])
}

model pagamentos {
  pagamento_id      Int                 @id @default(autoincrement())
  crianca_id        Int
  pagador_id        Int
  empresa_id        Int
  valor_total       Decimal             @db.Decimal(10, 2)
  tipo_pag_id       Int
  forma_pag_id      Int?
  mes_mensalidade   DateTime            @db.Date
  status_pag_id     Int
  data_pagamento    DateTime?           @default(now()) @db.Timestamp(6)
  logs_pagamentos   logs_pagamentos[]
  pagamento_crianca pagamento_crianca[]
  criancas          criancas            @relation(fields: [crianca_id], references: [crianca_id], onDelete: NoAction, onUpdate: NoAction)
  empresas          empresas            @relation(fields: [empresa_id], references: [empresa_id], onDelete: Cascade, onUpdate: NoAction)
  forma_pagamento   forma_pagamento?    @relation(fields: [forma_pag_id], references: [forma_pag_id], onDelete: NoAction, onUpdate: NoAction)
  responsaveis      responsaveis        @relation(fields: [pagador_id], references: [responsavel_id], onDelete: NoAction, onUpdate: NoAction)
  status_pagamento  status_pagamento    @relation(fields: [status_pag_id], references: [status_pag_id], onDelete: NoAction, onUpdate: NoAction)
  tipo_pagamento    tipo_pagamento      @relation(fields: [tipo_pag_id], references: [tipo_pag_id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([crianca_id, mes_mensalidade], map: "uq_pagamento_crianca_mes")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model planos_transporte {
  plano_id       Int        @id @default(autoincrement())
  nome           String     @db.VarChar(50)
  descricao      String?
  valor_base     Decimal    @db.Decimal(10, 2)
  tipo_reajuste  String?    @db.VarChar(20)
  valor_reajuste Decimal?   @default(0) @db.Decimal(10, 2)
  ativo          Boolean?   @default(true)
  created_at     DateTime?  @default(now()) @db.Timestamp(6)
  desconto       Decimal?   @default(0) @db.Decimal(10, 2)
  multa          Decimal?   @default(0) @db.Decimal(10, 2)
  criancas       criancas[]
}

model responsaveis {
  responsavel_id        Int                     @id @default(autoincrement())
  principal             Boolean?                @default(false)
  user_id               Int
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  updated_at            DateTime?               @default(now()) @db.Timestamp(6)
  criancas_responsaveis criancas_responsaveis[]
  pagamentos            pagamentos[]
  usuarios              Usuario                 @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

model rotina_transporte {
  rotina_id                                                  Int          @id @default(autoincrement())
  empresa_id                                                 Int
  crianca_id                                                 Int
  motorista_id                                               Int
  dia_id                                                     Int
  tipo_trajeto_id                                            Int
  endereco_origem_id                                         Int
  endereco_destino_id                                        Int
  horario_previsto                                           DateTime     @db.Time(6)
  ativo                                                      Boolean?     @default(true)
  observacao                                                 String?
  ordem                                                      Int?
  created_at                                                 DateTime?    @default(now()) @db.Timestamp(6)
  updated_at                                                 DateTime?    @default(now()) @db.Timestamp(6)
  criancas                                                   criancas     @relation(fields: [crianca_id], references: [crianca_id], onDelete: NoAction, onUpdate: NoAction)
  dias_semana                                                dias_semana  @relation(fields: [dia_id], references: [dia_id], onDelete: NoAction, onUpdate: NoAction)
  empresas                                                   empresas     @relation(fields: [empresa_id], references: [empresa_id], onDelete: Cascade, onUpdate: NoAction)
  enderecos_rotina_transporte_endereco_destino_idToenderecos enderecos    @relation("rotina_transporte_endereco_destino_idToenderecos", fields: [endereco_destino_id], references: [endereco_id], onDelete: NoAction, onUpdate: NoAction)
  enderecos_rotina_transporte_endereco_origem_idToenderecos  enderecos    @relation("rotina_transporte_endereco_origem_idToenderecos", fields: [endereco_origem_id], references: [endereco_id], onDelete: NoAction, onUpdate: NoAction)
  motoristas                                                 motoristas   @relation(fields: [motorista_id], references: [motorista_id], onDelete: NoAction, onUpdate: NoAction)
  tipo_trajeto                                               tipo_trajeto @relation(fields: [tipo_trajeto_id], references: [tipo_trajeto_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model status_documento {
  status_doc_id Int        @id @default(autoincrement())
  status        String     @db.VarChar(20)
  veiculos      veiculos[]
}

model status_pagamento {
  status_pag_id Int          @id @default(autoincrement())
  tipo          String       @unique @db.VarChar(20)
  pagamentos    pagamentos[]
}

model tipo_escola {
  tipo_escola_id Int       @id @default(autoincrement())
  tipo           String    @unique @db.VarChar(50)
  escolas        escolas[]
}

model tipo_pagamento {
  tipo_pag_id Int          @id @default(autoincrement())
  metodo      String       @unique @db.VarChar(50)
  pagamentos  pagamentos[]
}

model tipo_responsavel {
  tipo_responsavel_id   Int                     @id @default(autoincrement())
  tipo                  String                  @db.VarChar(50)
  criancas_responsaveis criancas_responsaveis[]
}

model tipo_trajeto {
  tipo_trajeto_id   Int                 @id @default(autoincrement())
  nome              String              @unique @db.VarChar(20)
  rotina_transporte rotina_transporte[]
}

model usuarios_endereco {
  user_id     Int
  endereco_id Int
  tipo        String?   @db.VarChar(30)
  principal   Boolean?  @default(false)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  enderecos   enderecos @relation(fields: [endereco_id], references: [endereco_id], onDelete: Cascade, onUpdate: NoAction)
  usuarios    Usuario   @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, endereco_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model veiculos {
  veiculo_id        Int                 @id @default(autoincrement())
  empresa_id        Int
  placa_veiculo     String              @unique @db.VarChar(10)
  marca_veiculo     String              @db.VarChar(50)
  modelo_veiculo    String              @db.VarChar(50)
  capacidade        Int?
  ano_veiculo       Int?
  status_doc_id     Int
  ativo             Boolean?            @default(true)
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  updated_at        DateTime?           @default(now()) @db.Timestamp(6)
  motorista_veiculo motorista_veiculo[]
  empresas          empresas            @relation(fields: [empresa_id], references: [empresa_id], onDelete: Cascade, onUpdate: NoAction)
  status_documento  status_documento    @relation(fields: [status_doc_id], references: [status_doc_id], onDelete: NoAction, onUpdate: NoAction)
}
